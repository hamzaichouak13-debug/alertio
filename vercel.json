{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,

  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/cron/sync.ts",
      "use": "@vercel/node",
      "config": { "maxDuration": 60 }
    },
    {
      "src": "api/!(cron)/**/*.ts",
      "use": "@vercel/node",
      "config": { "maxDuration": 15 }
    }
  ],

  "routes": [
    {
      "src": "/api/profile/(?<uid>[^/]+)",
      "dest": "/api/profile/[uid].ts?uid=$uid",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY"
      }
    },
    {
      "src": "/api/jobs/(?<id>[^/]+)",
      "dest": "/api/jobs/[id].ts?id=$id",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY"
      }
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],

  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "*/10 * * * *"
    }
  ]
}